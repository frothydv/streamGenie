{
  "manifest_version": 3,
  "name": "Stream Genie",
  "version": "0.9.2",
  "description": "Hover over anything in the stream. A popup tells you what it is. Community-built annotations for any game, right inside the video.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.twitch.tv/*",
    "https://cdn.jsdelivr.net/*",
    "https://raw.githubusercontent.com/*",
    "https://*.workers.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.twitch.tv/*"],
      "js": ["config.js", "matcher-core.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Stream Overlay",
    "default_popup": "popup.html"
  },
  "commands": {
    "capture-trigger": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "Alt+Shift+C"
      },
      "description": "Capture a new trigger (reserved for contribution flow)"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["references/*.png"],
      "matches": ["https://*.twitch.tv/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
